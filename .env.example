PORT=3000

# Optional: RapidAPI key for live Indian railway data.
RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: NVIDIA developer key for AI itinerary generation.
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Demo fallbacks keep the app usable even without live API keys.
ALLOW_DEMO_DATA=true
